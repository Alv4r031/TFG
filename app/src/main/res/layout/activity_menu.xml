<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="0dp"
    tools:context=".MenuActivity">

    <!-- Header -->
    <View
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="96dp"
        android:background="@color/surface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Avatar circular y nombre -->
    <ImageView
        android:id="@+id/imgLogoLogout"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:src="@drawable/ludomix_logo"
        android:contentDescription="@string/app_logo"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_circle_logo"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/txtUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/guest"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textColorPrimary"
        app:layout_constraintTop_toTopOf="@id/topBar"
        app:layout_constraintStart_toEndOf="@id/imgLogoLogout"
        android:layout_marginStart="12dp"
        android:layout_marginTop="28dp" />

    <!-- Botón adicional para cerrar sesión (texto) -->

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="@string/logout_text"
        android:textSize="12sp"
        android:background="@drawable/bg_outline_blue"
        android:textColor="@color/cyan"
        app:layout_constraintBottom_toTopOf="@id/btnScores"
        app:layout_constraintStart_toStartOf="@id/btnScores"
        app:layout_constraintEnd_toEndOf="@id/btnScores"
        android:layout_marginBottom="8dp" />

    <!-- Boton Mis Puntuaciones naranja -->

    <!-- Título principal -->

    <Button
        android:id="@+id/btnScores"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/btn_orange_bg"
        android:text="@string/menu_scores"
        android:textColor="@color/buttonTextLight"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBar" />

    <!-- Botón para invitar a iniciar sesión/registrarse cuando el usuario es invitado -->
    <Button
        android:id="@+id/btnAuth"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_button_blue"
        android:text="@string/login_signin"
        android:textColor="@color/buttonTextLight"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBar"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/games_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/textColorPrimary"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:id="@+id/menuButtons"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp">

        <Button
            android:id="@+id/btnGuessNumber"
            style="@style/LudoMixMenuButton"
            android:text="@string/menu_guess_number" />

        <Button
            android:id="@+id/btnRps"
            style="@style/LudoMixMenuButton"
            android:text="@string/menu_rps" />

        <Button
            android:id="@+id/btnTicTacToe"
            style="@style/LudoMixMenuButton"
            android:text="@string/menu_ttt" />

        <Button
            android:id="@+id/btnMemoryGame"
            style="@style/LudoMixMenuButton"
            android:text="@string/menu_memory" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
