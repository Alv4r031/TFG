<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@color/background_dark"
    >

    <TextView
        android:id="@id/txtResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/rps_start_prompt"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textColor="@color/textColorPrimary" />

    <TextView
        android:id="@id/txtScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/score_text"
        android:layout_marginBottom="24dp"
        android:textColor="@color/textColorSecondary" />

    <!-- Área central: muestra la elección grande del jugador y la CPU -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <!-- Contenedor jugador: etiqueta de wins encima del icono -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginEnd="48dp">

            <TextView
                android:id="@+id/playerWinsView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tú: 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/playerChoiceView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="72sp"
                android:contentDescription="@string/desc_player_choice"
                android:textColor="@color/textColorPrimary" />

        </LinearLayout>

        <!-- Contenedor CPU: etiqueta de wins encima del icono -->
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center">

            <TextView
                android:id="@+id/cpuWinsView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CPU: 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/textColorPrimary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/cpuChoiceView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="72sp"
                android:contentDescription="@string/desc_cpu_choice"
                android:textColor="@color/textColorPrimary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Botones con emojis representativos -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        style="?android:attr/buttonBarStyle"
        android:layout_marginTop="40dp">

        <Button
            android:id="@+id/btnRock"
            style="@style/IconButton"
            android:text="@string/emoji_rock"
            android:textSize="28sp"
            android:onClick="playRock"
            android:textColor="@color/textColorPrimary" />

        <Button
            android:id="@+id/btnPaper"
            style="@style/IconButton"
            android:text="@string/emoji_paper"
            android:textSize="28sp"
            android:onClick="playPaper"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:textColor="@color/textColorPrimary" />

        <Button
            android:id="@+id/btnScissors"
            style="@style/IconButton"
            android:text="@string/emoji_scissors"
            android:textSize="28sp"
            android:onClick="playScissors"
            android:textColor="@color/textColorPrimary" />
    </LinearLayout>

    <!-- Botón para volver al menú (ancho reducido) -->
    <Button
        android:id="@+id/btnBackToMenu"
        style="@style/LudoMixMenuButton"
        android:text="@string/back_to_menu" />

    <Button
        android:id="@+id/btnResetRps"
        style="@style/LudoMixMenuButton"
        android:text="Reiniciar" />

</LinearLayout>
