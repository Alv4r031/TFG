<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_difficulty"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/cyan"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnTTTEasy"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/easy"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:textColor="@color/background"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtEasyStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ttt_points_status"
            android:textColor="@color/gray_text"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnTTTMedium"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/medium"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:textColor="@color/background"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txtMediumStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ttt_locked_need"
            android:textColor="@color/gray_text"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnTTTHard"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/hard"
            android:textStyle="bold"
            android:background="@drawable/bg_button_blue"
            android:textColor="@color/background"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/txtHardStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ttt_locked_need"
            android:textColor="@color/gray_text"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/generic_back"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_button_orange"
            android:textColor="@color/white" />

    </LinearLayout>

</ScrollView>
