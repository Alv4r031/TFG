<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2000BFFF" /> <!-- suave overlay para glow -->
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Main button -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyan" />
            <corners android:radius="12dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
</layer-list>
