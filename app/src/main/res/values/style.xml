<resources>
    <!-- Estilo base (compatibilidad) -->
    <style name="AppTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:buttonStyle">@style/PrimaryButton</item>
        <item name="android:textColor">@color/textColorPrimary</item>
    </style>

    <!-- Botón primario (cian fondo, texto oscuro) reutilizable -->
    <style name="PrimaryButton" parent="Widget.AppCompat.Button">
        <!-- Usar drawable con esquinas redondeadas -->
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">@color/buttonText</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Estilo para los botones del menú principal (relleno cian con texto oscuro) -->
    <style name="MenuButton" parent="@style/PrimaryButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:textColor">@color/buttonText</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">14dp</item>
    </style>

    <!-- Estilo para botones de los juegos -->
    <style name="GameButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_margin">8dp</item>
    </style>

    <style name="TicTacToeButton">
        <item name="android:layout_width">100dp</item>
        <item name="android:layout_height">100dp</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:backgroundTint">@color/surface</item>
        <item name="android:textSize">48sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textColorPrimary</item>
    </style>

    <style name="MemoryCard">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:backgroundTint">@color/surface</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textColorPrimary</item>
    </style>

    <style name="IconButton" parent="@style/PrimaryButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/buttonText</item>
    </style>

</resources>
