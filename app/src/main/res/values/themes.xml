<resources>
    <!-- Tema base usando AppCompat (compatible sin Material3) -->
    <style name="Base.Theme.LudoMix" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Colores principales -->
        <item name="android:colorPrimary">@color/colorPrimary</item>
        <item name="android:colorPrimaryDark">@color/colorPrimaryVariant</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:colorForeground">@color/surface</item>
        <item name="android:textColor">@color/textColorPrimary</item>
        <item name="android:textColorSecondary">@color/textColorSecondary</item>

        <!-- Toolbar y botones personalizados -->
        <item name="android:toolbarStyle">@style/TopAppBar</item>
        <item name="android:buttonStyle">@style/PrimaryButton</item>
    </style>

    <style name="Theme.LudoMix" parent="Base.Theme.LudoMix" />

    <!-- Barra superior personalizada (AppCompat) -->
    <style name="TopAppBar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="android:titleTextAppearance">@style/TopAppBarTitle</item>
    </style>

    <style name="TopAppBarTitle">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/textColorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>


</resources>